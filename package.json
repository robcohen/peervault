{
  "name": "peervault",
  "version": "0.2.66",
  "description": "P2P sync for Obsidian using Loro CRDT and Iroh transport",
  "type": "module",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "bun run esbuild.config.mjs",
    "dev": "bun run esbuild.config.mjs --watch",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun run e2e/runner.ts",
    "test:e2e:scaled": "bun run e2e/scaled-runner.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "package": "bun run build && cd dist && tar -czvf ../peervault-release.tar.gz main.js manifest.json styles.css"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.13.1",
    "typescript": "^6.0.0"
  },
  "dependencies": {}
}
